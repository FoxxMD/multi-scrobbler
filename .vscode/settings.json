{
    "mochaExplorer.require": "tsx/esm",
    "mochaExplorer.timeout": 1200000,
    "mochaExplorer.exit": true,
    "search.exclude": {
        "**/.docusaurus": true,
        "**/build": true,
        "**/schema": true
    },
    "tailwindCSS.files.exclude": [
        "docsite/**"
    ],
    "files.associations": {
        "*.css": "tailwindcss",
        "**/config/*.json": "jsonc"
    },
    "tailwindCSS.experimental.configFile": "src/client/index.css",
    
}