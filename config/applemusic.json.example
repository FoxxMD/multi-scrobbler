[
  {
    "id": "myAppleMusic",
    "name": "My Apple Music",
    "enable": true,
    "clients": [],
    "data": {
      // either key or token needs to be provided
      "key": {
        "id": "2HPSNJZ88N",
        "teamId": "SN6YASW8G4",
        "p8": "-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMGByqGSM49AgEG...-----END PRIVATE KEY-----"
